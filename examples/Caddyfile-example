# ============================================================
# Caddy 作为 Trojan 的伪装后端
# ============================================================
#
# 架构:
#   Client → Trojan (443, TLS) → 有效请求 → 目标服务器
#                              → 无效请求 → Caddy (8080) → 伪装网站
#
# Trojan 配置:
#   "remote_addr": "127.0.0.1",
#   "remote_port": 8080
#
# ============================================================

:8080 {
    root * /var/www/html
    file_server
    
    # 反向代理示例（可选）
    # reverse_proxy /api/* localhost:3000
    
    log {
        output file /var/log/caddy/access.log
    }
}
