# Linux packaging metadata draft for the Trojan Pro Client.
# Source this file from packaging scripts and adjust values per release.

DISPLAY_NAME="Trojan Pro Client"
PACKAGE_NAME="trojan-pro-client"
EXECUTABLE_NAME="trojan_pro_client"
DESKTOP_FILE_ID="trojan-pro-client.desktop"
DESKTOP_STARTUP_WM_CLASS="trojan_pro_client"
ICON_NAME="trojan-pro-client"
ICON_SOURCE="packaging/linux/assets/trojan-pro-client.png"

CHANNEL="stable"
VERSION_LABEL="1.4.0"
DEB_VERSION="1.4.0-1"
PACKAGE_ARCH="amd64"
ARTIFACT_STEM="trojan-pro-client"

PACKAGE_SECTION="net"
PACKAGE_PRIORITY="optional"
MAINTAINER_NAME="Trojan-Pro"
MAINTAINER_EMAIL="noreply@trojan-pro.invalid"
HOMEPAGE="https://github.com/proxy-trojan/trojan-obfuscation"
PACKAGE_DEPENDS="libgtk-3-0, libsecret-1-0, libstdc++6"
PACKAGE_DESCRIPTION_SHORT="Trojan-Pro desktop client"
PACKAGE_DESCRIPTION_LONG="Desktop-first Trojan-Pro client with local profile management, secure storage, diagnostics export, and adapter-backed controller workflow."

DESKTOP_COMMENT="Desktop-first Trojan-Pro client shell"
DESKTOP_CATEGORIES="Network;Security;"
DESKTOP_KEYWORDS="Trojan;Proxy;Network;Security;"

INSTALL_PREFIX="/opt/trojan-pro-client"
RELEASE_BUNDLE_RELATIVE_DIR="client/build/linux/x64/release/bundle"
ARTIFACT_OUTPUT_RELATIVE_DIR="packaging/linux/artifacts"
STAGING_RELATIVE_DIR="packaging/linux/staging"
